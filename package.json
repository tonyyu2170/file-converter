{
  "name": "file-converter",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/copy-bg-models.mjs && node scripts/copy-ffmpeg-core.mjs",
    "build": "next build",
    "postbuild": "node scripts/check-bundle-isolation.mjs",
    "postinstall": "node scripts/fetch-bg-models.mjs && node scripts/copy-bg-models.mjs && node scripts/copy-ffmpeg-core.mjs",
    "start": "next start",
    "lint": "biome check src tests",
    "lint:fix": "biome check --write src tests",
    "format": "biome format --write src tests",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@ffmpeg/core": "^0.12.10",
    "@ffmpeg/core-mt": "^0.12.10",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@huggingface/transformers": "^4.2.0",
    "@pdf-lib/fontkit": "^1.1.1",
    "client-zip": "^2.5.0",
    "comlink": "^4.4.2",
    "fast-xml-parser": "^5.7.2",
    "fflate": "^0.8.2",
    "highlight.js": "^11.11.1",
    "libheif-js": "^1.19.8",
    "markdown-it": "^14.1.1",
    "next": "^15.0.0",
    "pdf-lib": "^1.17.0",
    "pdfjs-dist": "^5.7.284",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@biomejs/biome": "^1.9.0",
    "@playwright/test": "^1.48.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "docx": "^9.6.1",
    "jsdom": "^25.0.0",
    "postcss": "^8.4.0",
    "subset-font": "^2.5.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
